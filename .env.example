# Copy to .env for integration tests. Never commit .env.
# Integration tests are skipped automatically if these are not set.

MIKROTIK_TEST_HOST=192.168.88.1
MIKROTIK_TEST_PORT=8728
MIKROTIK_TEST_USER=admin
MIKROTIK_TEST_PASS=

# User Manager "customer" (internal UM concept — NOT a RouterOS login).
# Tests always authenticate to the router using the credentials above;
# this value is passed as the customer parameter on UM commands.
MIKROTIK_TEST_UM_USER=admin
